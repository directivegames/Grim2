{
  "scripts": {
    "build": "pnpm run generate-property-metadata && tsc && pnpm exec tsx ./scripts/genesys/write-build-stamp.ts",
    "turbo:build": "turbo run build",
    "generate-property-metadata": "pnpm exec tsx node_modules/@gnsx/genesys.js/scripts/generate-property-metadata.ts src/game-data.ts",
    "build-project": "pnpm exec tsx ./scripts/genesys/build-project.ts",
    "postinstall": "pnpm exec tsx ./scripts/genesys/post-install.ts && pnpm rebuild @gnsx/genesys.harness",
    "lint": "eslint . --fix --ext .ts,.tsx",
    "remove-engine-comments": "pnpm exec tsx ./scripts/genesys/remove-engine-comments.ts",
    "sync-assets": "pnpm exec tsx ./scripts/genesys/sync-project-assets-to-dist.ts",
    "dev": "pnpm exec tsx ./scripts/genesys/dev/generate-manifest.ts && vite",
    "validate-prefabs": "pnpm exec tsx ./scripts/genesys/validate-prefabs.ts",
    "install-developer-skills": "pnpm exec tsx ./scripts/genesys/install-developer-skills.ts",
    "apply-lightmaps": "pnpm exec tsx ./tools/apply-lightmaps-cli.ts",
    "add-uv2": "pnpm exec tsx ./tools/add-uv2-to-glbs-cli.ts"
  },
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "dependencies": {
    "@gnsx/genesys.harness": "latest",
    "@gnsx/genesys.js": "10.7.0",
    "three": "0.184.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@gnsx/genesys.harness"
    ]
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@modelcontextprotocol/sdk": "1.22.0",
    "@types/jsdom": "21.1.7",
    "@types/node": "24.12.0",
    "@types/three": "0.184.1",
    "@types/ws": "8.18.1",
    "@typescript-eslint/parser": "8.29.1",
    "@typescript-eslint/utils": "8.38.0",
    "ajv": "8.20.0",
    "canvas": "3.1.0",
    "esbuild": "0.28.0",
    "eslint": "9.24.0",
    "get-port": "7.1.0",
    "jsdom": "26.1.0",
    "nanoid": "5.1.11",
    "ts-morph": "26.0.0",
    "tsx": "4.20.3",
    "turbo": "2.8.11",
    "typescript": "5.8.3",
    "vite": "7.1.7",
    "vite-plugin-mkcert": "1.17.8",
    "vite-plugin-node-polyfills": "0.24.0",
    "ws": "8.18.2",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "name": "Grim",
  "version": "0.0.1"
}